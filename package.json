{
  "name": "star-trade-station",
  "version": "1.0.0",
  "description": "星际贸易站 - 放置经营游戏",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node scripts/fix-electron-html.cjs",
    "fix-paths": "sed -i '' 's|src=\"/assets/|src=\"./assets/|g; s|href=\"/assets/|href=\"./assets/|g' dist/index.html",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:aerospace": "playwright test tests/e2e/aerospace-test.runner.ts",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-forge make",
    "electron:package": "npm run build && electron-forge package"
  },
  "dependencies": {
    "phaser": "^3.60.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.2.0",
    "@electron-forge/maker-deb": "^7.2.0",
    "@electron-forge/maker-dmg": "^7.2.0",
    "@electron-forge/maker-rpm": "^7.2.0",
    "@electron-forge/maker-squirrel": "^7.2.0",
    "@electron-forge/maker-zip": "^7.2.0",
    "@playwright/test": "^1.58.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.0.0",
    "vite": "^4.4.0",
    "vitest": "^0.34.0"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "星际贸易站",
        "executableName": "star-trade-station",
        "icon": "./assets/icon",
        "asar": true
      },
      "makers": [
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin",
            "linux",
            "win32"
          ]
        },
        {
          "name": "@electron-forge/maker-dmg",
          "platforms": [
            "darwin"
          ]
        },
        {
          "name": "@electron-forge/maker-squirrel",
          "platforms": [
            "win32"
          ]
        },
        {
          "name": "@electron-forge/maker-deb",
          "platforms": [
            "linux"
          ]
        }
      ]
    }
  },
  "build": {
    "appId": "com.startrade.station",
    "productName": "星际贸易站",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "星际贸易站",
      "compression": "lzma2",
      "solid": true,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "asar": true
  }
}
